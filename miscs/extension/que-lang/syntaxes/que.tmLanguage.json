{
  "scopeName": "source.que",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.line.que", "match": ";.*$" }]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.que", "begin": "\"", "end": "\"" },
        { "name": "string.quoted.single.que", "begin": "'", "end": "'" }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.que",
          "match": "\\b(Int|Float|Bool|Char)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.que",
          "match": "\\b(do|let|let~|let\\*|loop|if|unless|cond|lambda|mod|length|as|get|at|set|pop|push|pull|swap|emod|not|and|or|identity|boole-set|boole-eqv|eq|integer|floating|boolean|variable|que|string|chars|digits|vector|bigint|tuple|table|fst|snd|car|cdr|has|in-bounds|apply|eq|comp|matrix|shell|Vector|String|Matrix|BigInt|Tuple|Table|Set|Que|Integer|Float|Boolean)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.que",
          "match": "\\b(true|false|nil|infinity)\\b"
        },
        {
          "name": "support.function.que",
          "match": "\\b(enumerate|sum|nl|sp|ep|dq|sq|bt|map|filter|reduce|every|some|empty|copy|reverse|slice|cons|sort|range|square|sqrt|expt|floor|ceil|max|min|abs|first|last|count|points|zip|unzip|permutation|window|flat|pair|product|find|lcm|gcd|call|odd|even|upper|lower|match|digit|fill|take|drop|clamp|one|zero|ones|zeroes|positive|negative|invert|divisible|maximum|minimum|for|subset|scan|extreme|neighborhood|unique|transpose|interleave|intersperse|cycle|replicate|avg|mean|median|each|const|select|exclude|group|append|tail|head|split|list-dir|delete|mkdir|move|read|write|curl)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.que",
          "match": "(\\+|\\-|\\*|\\/|%=|\\=\\=|\\!\\=|\\>\\=|\\<\\=|\\&|\\||\\^|\\!|\\~|\\?|\\:|\\.|\\|\\>|\\+\\+|\\-\\-)"
        }
      ]
    },
    "numbers": {
      "patterns": [{ "name": "constant.numeric.que", "match": "\\b[0-9]+\\b" }]
    }
  }
}
